# Maintainer: Thomas Esders <thomas@nobsagile.com>
pkgname=cylenivo-bin
pkgver=0.57.15
pkgrel=1
pkgdesc="Flow metrics for software teams — cycle time, lead time, forecasting. Local desktop app, no accounts."
arch=('x86_64')
url="https://cylenivo.com"
license=('LicenseRef-MIT-Commons-Clause')
depends=('webkit2gtk-4.1' 'gtk3' 'libayatana-appindicator')
makedepends=('binutils')
optdepends=('libappindicator-gtk3: alternative tray icon support')
provides=('cylenivo')
conflicts=('cylenivo')
options=('!debug' '!strip')

source_x86_64=("${pkgname}-${pkgver}.deb::https://github.com/nobsagile/cylenivo/releases/download/v${pkgver}/Cylenivo_${pkgver}_amd64.deb")
sha256sums_x86_64=('43fad4885191a200d4880798e55149a95f863788b0fed6fd5f0970ec767c3e27')

package() {
    cd "$srcdir"

    # Extract the .deb archive
    ar x "${pkgname}-${pkgver}.deb"

    # Extract data tarball (may be .gz, .xz or .zst depending on build)
    if [ -f data.tar.gz ]; then
        tar -xzf data.tar.gz -C "$pkgdir"
    elif [ -f data.tar.xz ]; then
        tar -xJf data.tar.xz -C "$pkgdir"
    elif [ -f data.tar.zst ]; then
        tar --use-compress-program=unzstd -xf data.tar.zst -C "$pkgdir"
    fi

    # Fix permissions
    chmod 755 "$pkgdir/usr/bin/cylenivo"
    find "$pkgdir" -name "cylenivo-server-*" -type f -exec chmod 755 {} \;
}
