{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cylenivo",
  "version": "1.1.1",
  "identifier": "com.cylenivo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npx concurrently \"npm run dev\" \"npm run server:dev\"",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cylenivo",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "shortDescription": "Flow metrics for software teams",
    "longDescription": "Analyze cycle time, lead time, and throughput from Jira exports. Fully local, no cloud.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/cylenivo-server"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBRDNERUJCODg3RjA1NjAKUldSZ0JYK0l1OTdUdW4vQWs5NEZZTVpBL0ovRG45UUE3QmU2VENTd2hBNXZoUmZjTUJoTktmWWYK",
      "endpoints": [
        "https://github.com/nobsagile/cylenivo/releases/latest/download/latest.json"
      ]
    }
  }
}
